---
import Layout from '../../layouts/Default.astro';
import { Icon } from "astro-icon";

---

<Layout title="VPN">
    <div class="grid justify-items-center">
        <a href="/vpnation"><h1 class="text-5xl sm:text-6xl md:text-7xl my-6">VPN</h1></a>
        <!-- <h2 class="text-3xl sm:text-4xl md:text-5xl">Настройка VPN</h2> -->
        
              <ul class="steps steps-vertical sm:steps-horizontal">
                <li class="step step-primary"><a class="m-0" href="/vpnation/step-wg">Установка WireGuard</a></li>
                <li class="step"><a class="m-0" href="/vpnation/step-config">Бот</a></li>
                <li class="step"><a class="m-0" href="/vpnation/step-import">Импорт настроек</a></li>
                <li data-content="★" class="step step-secondary"></li>
        
              </ul>
              <h3 class="divider my-6" >Установите WireGuard для вашей платформы:</h3>
        
              <ul class="menu menu-horizontal bg-base-100 rounded-box">
              <li class="mx-auto" >
                  <a href="https://itunes.apple.com/us/app/wireguard/id1441195209?ls=1&mt=8" target="_blank">
                    <Icon name="tabler:brand-appstore" width='32' />AppStore
                  </a>
                </li>
                <li class="mx-auto" >
                  <a href="https://play.google.com/store/apps/details?id=com.wireguard.android" target="_blank">
                    <Icon name="simple-icons:googleplay" width="28" />GooglePlay
                  </a>
                </li>
              </ul>
              <p><a class="btn" href="/vpnation/step-config">Следующий шаг</a></p>
        
            </div>
</Layout>